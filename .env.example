# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Anthropic API (for AI 伴走者)
ANTHROPIC_API_KEY=sk-ant-...

# 組織作成 / community ログインのセッション発行で使用 (RLS バイパス)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# community_dashboard 連携ログイン (OAuth)。client_id 設定でログイン画面に
# 「community_dashboard でログイン」が表示される。client_id はブラウザに露出可。
NEXT_PUBLIC_COMMUNITY_CLIENT_ID=
# confidential client の場合のみ設定 (サーバ専用・絶対に NEXT_PUBLIC_ にしない)。
COMMUNITY_CLIENT_SECRET=
# 任意: community のベースURL (既定は提供された Supabase プロジェクト)
# NEXT_PUBLIC_COMMUNITY_BASE=https://ghxdhsnqhsybmghfqyfd.supabase.co
# community_dashboard でログインした人が自動で所属する組織の slug。
# 未設定なら personal org fallback のみ (組織所属無し)。
# 例: NEO_COMMUNITY_ORG_SLUG=neo-academia2026
NEO_COMMUNITY_ORG_SLUG=
# 上記組織を特定の cohort (期) のメンバー限定にする場合の cohort id。
# community_dashboard の cohorts テーブルの id を設定 (例: 2期の id)。
# 設定時のみ、その cohort に所属する人だけが NEO_COMMUNITY_ORG_SLUG の組織へ
# 参加・アクセスできる。未設定なら従来どおり community 認証者全員が参加可。
NEO_COMMUNITY_REQUIRED_COHORT_ID=2
